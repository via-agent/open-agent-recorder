{
  "name": "open-agent-recorder",
  "version": "0.1.0",
  "private": true,
  "description": "Open source flight recorder for AI agents and LLM applications.",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm -r check",
    "dev:collector": "pnpm --filter @open-agent-recorder/collector dev",
    "example:node": "pnpm --filter node-basic start",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
