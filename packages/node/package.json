  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "check": "tsc -b tsconfig.json",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@open-agent-recorder/core": "workspace:^"
  },
